# BotFather token
BOT_TOKEN=1234567890:your_botfather_token_here

# PostgreSQL URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/community_sync_bot

# Comma-separated list of Telegram user IDs allowed as admins
ADMIN_TELEGRAM_IDS=123456789

# Optional timezone used for cron schedules without explicit TZ
DEFAULT_TIMEZONE=UTC

# How often to re-read schedule rows from DB (seconds)
SCHEDULE_REFRESH_SECONDS=120
